# =============================================================================
# Utility Manager — environment variables
# Copy to .env.local and fill in values from Supabase.
# =============================================================================

# --- App ---
PORT=3001
NEXT_PUBLIC_SITE_URL=http://localhost:3001

# --- Supabase (required for database + auth) ---
# Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_public_key

# Server only — NEVER expose in browser or commit real value to git
# Dashboard → Project Settings → API → service_role
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Database password — only for local migrations (npm run db:migrate)
# Dashboard → Project Settings → Database → Database password
# SUPABASE_DB_PASSWORD=your_database_password
# Pooler region (Dashboard → Database → Connection string), default eu-west-1
# SUPABASE_DB_REGION=eu-west-1
# Or full connection string (recommended if direct db.* host fails on your network):
# DATABASE_URL=postgresql://postgres.YOUR_PROJECT_REF:password@aws-0-eu-west-1.pooler.supabase.com:5432/postgres

# --- Contact email SMTP (server only, optional notification after web submission) ---
# CONTACT_SMTP_HOST=smtp.example.com
# CONTACT_SMTP_PORT=587
# CONTACT_SMTP_USER=radijumi@utility.lv
# CONTACT_EMAIL_PASSWORD=your_smtp_password

# --- Admin seed (npm run db:seed-admin) — local only, never commit real values ---
# ADMIN_SEED_EMAIL=admin@example.com
# ADMIN_SEED_PASSWORD=your_secure_password
