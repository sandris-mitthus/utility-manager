# =============================================================================
# Utility Manager — environment variables
# Copy to .env.local and fill in values from Supabase.
# =============================================================================

# --- App ---
PORT=3001
NEXT_PUBLIC_SITE_URL=http://localhost:3001

# --- Supabase (required for database + auth) ---
# Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_public_key

# Server only — NEVER expose in browser or commit real value to git
# Dashboard → Project Settings → API → service_role
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Database password — only for local migrations (npm run db:migrate)
# Dashboard → Project Settings → Database → Database password
# SUPABASE_DB_PASSWORD=your_database_password
# Pooler region (Dashboard → Database → Connection string), default eu-west-1
# SUPABASE_DB_REGION=eu-west-1
# Or full connection string (recommended if direct db.* host fails on your network):
# DATABASE_URL=postgresql://postgres.YOUR_PROJECT_REF:password@aws-0-eu-west-1.pooler.supabase.com:5432/postgres

# --- Contact email SMTP (server only, optional notification after web submission) ---
# CONTACT_SMTP_HOST=smtp.example.com
# CONTACT_SMTP_PORT=587
# CONTACT_SMTP_USER=radijumi@utility.lv
# CONTACT_EMAIL_PASSWORD=your_smtp_password

# --- Contact email IMAP (server only, inbound meter readings) ---
# CONTACT_IMAP_HOST=imap.example.com
# CONTACT_IMAP_PORT=993
# CONTACT_IMAP_USER=radijumi@utility.lv
# Uses CONTACT_EMAIL_PASSWORD when IMAP user is omitted.

# --- Cron (optional external scheduler for email fetch; not Vercel crons) ---
# CRON_SECRET=generate_a_long_random_string

# --- Google Sheets sync (server only, optional monthly readings export) ---
# Set GOOGLE_SHEETS_ENABLED=false to disable even when credentials are present.
# Share the Drive folder (or created files) with the service account email.
# GOOGLE_SHEETS_ENABLED=true
# GOOGLE_SERVICE_ACCOUNT_EMAIL=utility-sheets@your-project.iam.gserviceaccount.com
# GOOGLE_PRIVATE_KEY=replace_with_escaped_private_key_value
# Optional: place monthly spreadsheets in this Drive folder.
# GOOGLE_SHEETS_FOLDER_ID=your_google_drive_folder_id
# Alternative to GOOGLE_SERVICE_ACCOUNT_EMAIL + GOOGLE_PRIVATE_KEY:
# GOOGLE_SERVICE_ACCOUNT_JSON={"client_email":"utility-sheets@your-project.iam.gserviceaccount.com","private_key":"replace_with_escaped_private_key_value"}

# --- Admin seed (npm run db:seed-admin) — local only, never commit real values ---
# ADMIN_SEED_EMAIL=admin@example.com
# ADMIN_SEED_PASSWORD=your_secure_password
