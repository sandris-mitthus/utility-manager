{
  "name": "utility-manager",
  "version": "1.0.14",
  "private": true,
  "scripts": {
    "dev": "node --max-http-header-size=65536 ./node_modules/next/dist/bin/next dev -p 3001",
    "build": "next build",
    "start": "node --max-http-header-size=65536 ./node_modules/next/dist/bin/next start -p 3001",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "db:migrate": "node scripts/apply-migrations.mjs",
    "db:reload-schema": "node scripts/reload-postgrest-schema.mjs",
    "db:seed-admin": "node scripts/seed-admin.mjs",
    "db:test": "node scripts/test-supabase.mjs"
  },
  "dependencies": {
    "@supabase/ssr": "^0.12.0",
    "@supabase/supabase-js": "^2.108.1",
    "imapflow": "^1.4.1",
    "mailparser": "^3.9.10",
    "next": "16.2.7",
    "nodemailer": "^9.0.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/mailparser": "^3.4.6",
    "@types/node": "^20",
    "@types/nodemailer": "^8.0.1",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.7",
    "pg": "^8.21.0",
    "tailwindcss": "^4",
    "typescript": "^5"
  },
  "overrides": {
    "postcss": "^8.5.10"
  }
}
